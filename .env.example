# MAGFest Budget App - Environment Variables
# Copy this file to .env and customize for your environment

# ============================================================
# Development (default settings - no changes needed for local dev)
# ============================================================

APP_ENV=development
SECRET_KEY=dev-only-secret-key-change-in-production
# DATABASE_URL not set = uses local SQLite in instance/

# ============================================================
# Production (AWS AppRunner)
# ============================================================
# Uncomment and set these values for production deployment:

# APP_ENV=production

#
# python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=your-secure-random-64-char-secret

# PostgreSQL connection string:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Set to true when running behind AWS AppRunner or other reverse proxy:
# BEHIND_PROXY=true

# ============================================================
# AWS Secrets Manager (Production)
# ============================================================
# ARN or name of the secret in AWS Secrets Manager
# AWS_SECRETS_ARN=

# AWS region (defaults to us-east-1)
AWS_REGION=us-east-1

# The secret should be a JSON object with keys matching env var names:
# {
#   "SECRET_KEY": "your-secret-key",
#   "DATABASE_URL": "postgresql://...",
#   "KEYCLOAK_CLIENT_SECRET": "...",
#   "GOOGLE_CLIENT_SECRET": "..."
# }
#
# Or for RDS secrets (auto-constructed into DATABASE_URL):
# {
#   "username": "dbuser",
#   "password": "dbpass",
#   "host": "mydb.xxx.us-east-1.rds.amazonaws.com",
#   "port": 5432,
#   "dbname": "magfest_budget"
# }

# ============================================================
# Authentication
# ============================================================

# Bootstrap admin accounts — created on first startup with SUPER_ADMIN role
# Format: email:Display Name,email:Display Name
# BOOTSTRAP_ADMINS=admin@example.org:Admin User

# Dev login: enables local user switcher for development/testing
# Requires explicit opt-in, blocked in production regardless of setting
DEV_LOGIN_ENABLED=true

# Auth Provider Selection
# AUTH_PROVIDER=keycloak

# --- Google OAuth ---
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
# GOOGLE_ALLOWED_DOMAINS=magfest.org,magwest.org,magstock.org

# --- Keycloak OAuth ---
# KEYCLOAK_URL=https://auth.magfest.org
# KEYCLOAK_REALM=master
# KEYCLOAK_CLIENT_ID=
# KEYCLOAK_CLIENT_SECRET=your-client-secret

# ============================================================
# Beta Testing Features
# ============================================================

# Enable role override and user impersonation for super-admins to test different permission levels
# Defaults to true in development, false in production
# BETA_TESTING_MODE=false

# ============================================================
# Environment Banner
# ============================================================

# Warning banner shown at top of page for non-production environments
# Automatically enabled when APP_ENV != production
# Customize the message:
# ENV_BANNER_MESSAGE=Staging Environment

# ============================================================
# Email Notifications (AWS SES)
# ============================================================

# Enable/disable email sending (notifications still logged when disabled)
# EMAIL_ENABLED=false

# From address (must be verified in SES)
# EMAIL_FROM_ADDRESS=noreply@magfest.org

# Base URL for links in emails
# BASE_URL=https://budget.magfest.org

# AWS SES Configuration
# AWS_SES_REGION=us-east-1

# AWS credentials (required on Heroku, optional on AWS with IAM roles)
# AWS_SES_ACCESS_KEY=AKIA...
# AWS_SES_SECRET_KEY=...

# Rate limits (safety mechanisms to prevent runaway email sends)
# EMAIL_HOURLY_LIMIT=50          # Max emails per hour
# EMAIL_DAILY_LIMIT=200          # Max emails per day
# EMAIL_CIRCUIT_BREAKER_THRESHOLD=5   # Failures that trigger circuit breaker
# EMAIL_CIRCUIT_BREAKER_WINDOW=10     # Minutes to count failures

# ============================================================
# Organization Settings
# ============================================================

# Organization email domains (comma-separated)
# Used to identify organization members for certain features
# ORG_EMAIL_DOMAINS=magfest.org,magwest.org,magstock.org

# ============================================================
# Checkout Settings
# ============================================================

# Checkout timeout in minutes (JSON dict format)
# CHECKOUT_TIMEOUTS={"APPROVER": 30, "SUPER_ADMIN": 120, "DEFAULT": 30}

# ============================================================
# Session
# ============================================================

SESSION_TIMEOUT_MINUTES=30